generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectType {
  NEW
  ONGOING
  ON_HOLD
  COMPLETED
  OVERDUE
}

enum FundType {
  YES
  NO
  FUNDED
}

model Project {
  id                  Int         @id @default(autoincrement())
  pid                 Int         @unique
  projectName         String
  ministryDept        String
  type                ProjectType
  description         String      @db.Text
  startDate           DateTime
  completionDate      DateTime?
  leadProgrammeManager String
  programmeManager    String
  status              String      @db.Text // Narrative meeting/progress description
  contractValue       String      // Stored as text per requirement
  fundAvailable       FundType
  isDraft             Boolean     @default(false)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  history             ProjectHistory[]
}

model ProjectHistory {
  id             Int      @id @default(autoincrement())
  projectId      Int
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  snapshot       Json     // Stores all field values at the time of modification
  modifiedAt     DateTime @default(now())
}

model Ministry {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Department {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PersonnelRole {
  LEAD_PM
  PM
}

model Personnel {
  id        Int           @id @default(autoincrement())
  name      String        @unique
  role      PersonnelRole
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}
